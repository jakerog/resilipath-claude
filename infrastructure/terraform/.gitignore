# Local terraform state (we use GCS backend so this should never exist locally)
terraform.tfstate
terraform.tfstate.backup
.terraform.tfstate.lock.info

# Your actual variable values — NEVER commit this
terraform.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
